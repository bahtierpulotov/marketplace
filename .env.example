DEBUG=True
SECRET_KEY=your-very-secret-django-key-change-in-production
JWT_SECRET=your-jwt-secret-key-change-in-production

DB_NAME=
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

GROQ_API_KEY=your-groq-api-key-here

# Барои сервер: IP ё домен + порт (бе пробел). Мисол: 157.180.29.248,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1
# Агар хол бошад, аз CORS_ALLOWED_ORIGINS мерос мегирад. Барои сервер ҳатман пур кунед:
# CSRF_TRUSTED_ORIGINS=http://157.180.29.248:8003,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Агар хол бошад, дар sidebar блоки «Тамос» намешавад — ин на Django /admin/ аст.
PLATFORM_CONTACT_EMAIL=
